<%= form_with model: feed, local: true do |f| %>
  <div class="form-card">
    <div style="margin-bottom:0.6rem;">
      <%= f.label :name, class: 'form-label' %>
      <%= f.text_field :name, placeholder: 'Ex: BBC News - World', class: 'form-input' %>
    </div>

    <div style="margin-bottom:0.6rem;">
      <%= f.label :url, class: 'form-label' %>
      <%= f.text_field :url, placeholder: 'https://example.com/feed.xml (ex: https://rss.cnn.com/rss/edition.rss)', class: 'form-input' %>
    </div>

    <div style="margin-bottom:0.6rem;">
      <%= f.label :category, class: 'form-label' %>
      <%= f.text_field :category, placeholder: 'Categoria (ex: news, tech, sports)', class: 'form-input' %>
    </div>

    <div class="form-actions">
      <%= f.submit 'Create Feed', class: 'btn' %>
      <%= link_to 'Voltar', feeds_path, class: 'btn' %>
    </div>
  </div>
<% end %>
